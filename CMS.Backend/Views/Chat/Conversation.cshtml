@model IEnumerable<CMS.Data.Entities.ChatMessage>

@{
    ViewData["Title"] = "Chat với " + ViewBag.Customer.FullName;
    var customer = (CMS.Data.Entities.Customer)ViewBag.Customer;
}

<div class="animate-fade-in">
    <div class="page-header">
        <div>
            <h2><i class="fa-solid fa-message"></i> Chat với @customer.FullName</h2>
            <div class="subtitle">@customer.Email</div>
        </div>
        <a asp-action="Index" class="btn-cyber btn-cyber-secondary">
            <i class="fa-solid fa-arrow-left"></i> Quay lại
        </a>
    </div>

    @* Khung chat *@
    <div style="background: var(--card-bg, #1a1a2e); border: 1px solid var(--border-color, #333); border-radius: 12px; overflow: hidden;">
        @* Chat messages area *@
        <div id="chatMessages" style="height: 500px; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 12px;">
            @foreach (var msg in Model)
            {
                <div style="display: flex; justify-content: @(msg.IsFromAdmin ? "flex-end" : "flex-start");">
                    <div style="
                        max-width: 70%;
                        padding: 12px 16px;
                        border-radius: @(msg.IsFromAdmin ? "16px 16px 4px 16px" : "16px 16px 16px 4px");
                        background: @(msg.IsFromAdmin ? "linear-gradient(135deg, #6366f1, #8b5cf6)" : "rgba(255,255,255,0.08)");
                        color: @(msg.IsFromAdmin ? "#fff" : "#e0e0e0");
                        word-break: break-word;
                    ">
                        <div style="font-size: 0.75rem; opacity: 0.7; margin-bottom: 4px;">
                            @(msg.IsFromAdmin ? "🛡️ Admin" : "👤 " + customer.FullName)
                            &bull; @msg.SentAt.ToString("HH:mm dd/MM")
                        </div>
                        <div style="font-size: 0.95rem; line-height: 1.5;">@msg.Content</div>
                    </div>
                </div>
            }
        </div>

        @* Form gửi tin nhắn *@
        <div style="border-top: 1px solid var(--border-color, #333); padding: 16px 24px; background: rgba(0,0,0,0.2);">
            <form asp-action="Reply" method="post" style="display: flex; gap: 12px; align-items: center;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="customerId" value="@customer.Id" />
                <input type="text" name="content" id="chatInput"
                       placeholder="Nhập tin nhắn trả lời..."
                       autocomplete="off"
                       style="
                           flex: 1;
                           padding: 12px 16px;
                           border: 1px solid var(--border-color, #444);
                           border-radius: 8px;
                           background: rgba(255,255,255,0.06);
                           color: #fff;
                           font-size: 0.95rem;
                           outline: none;
                           transition: border-color 0.3s;
                       "
                       onfocus="this.style.borderColor='#6366f1'"
                       onblur="this.style.borderColor='var(--border-color, #444)'" />
                <button type="submit" class="btn-cyber btn-cyber-primary" style="padding: 12px 24px;">
                    <i class="fa-solid fa-paper-plane"></i> Gửi
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto scroll to bottom on load
        (function () {
            var chatBox = document.getElementById('chatMessages');
            if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;
        })();

        // Auto-refresh: Poll for new messages every 5 seconds
        (function () {
            var customerId = @customer.Id;
            var chatBox = document.getElementById('chatMessages');
            var lastMsgId = @(Model.Any() ? Model.Last().Id : 0);

            setInterval(function () {
                fetch('/Chat/GetNewMessages?customerId=' + customerId + '&lastMessageId=' + lastMsgId)
                    .then(function (res) { return res.json(); })
                    .then(function (messages) {
                        if (messages.length > 0) {
                            messages.forEach(function (msg) {
                                var wrapper = document.createElement('div');
                                wrapper.style.display = 'flex';
                                wrapper.style.justifyContent = msg.isFromAdmin ? 'flex-end' : 'flex-start';

                                var bubble = document.createElement('div');
                                bubble.style.maxWidth = '70%';
                                bubble.style.padding = '12px 16px';
                                bubble.style.borderRadius = msg.isFromAdmin ? '16px 16px 4px 16px' : '16px 16px 16px 4px';
                                bubble.style.background = msg.isFromAdmin ? 'linear-gradient(135deg, #6366f1, #8b5cf6)' : 'rgba(255,255,255,0.08)';
                                bubble.style.color = msg.isFromAdmin ? '#fff' : '#e0e0e0';
                                bubble.style.wordBreak = 'break-word';

                                var meta = document.createElement('div');
                                meta.style.fontSize = '0.75rem';
                                meta.style.opacity = '0.7';
                                meta.style.marginBottom = '4px';
                                meta.textContent = (msg.isFromAdmin ? '🛡️ Admin' : '👤 @customer.FullName') + ' • ' + msg.sentAt;

                                var content = document.createElement('div');
                                content.style.fontSize = '0.95rem';
                                content.style.lineHeight = '1.5';
                                content.textContent = msg.content;

                                bubble.appendChild(meta);
                                bubble.appendChild(content);
                                wrapper.appendChild(bubble);
                                chatBox.appendChild(wrapper);

                                lastMsgId = msg.id;
                            });

                            chatBox.scrollTop = chatBox.scrollHeight;
                        }
                    })
                    .catch(function () { /* silent */ });
            }, 5000);
        })();
    </script>
}
