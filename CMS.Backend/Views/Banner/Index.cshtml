@model IEnumerable<CMS.Data.Entities.Banner>

@{
    ViewData["Title"] = "Quản lý Banner - Thien Pet Shop";

    var homeHeroBanners = Model.Where(b => b.Position == "HomeHero" && b.IsActive).OrderBy(b => b.SortOrder).ToList();

    var allBanners = Model.ToList();
}

@* Thêm biến css bảng màu petshop dùng riêng cho trang *@
<style>
    :root {
        --pet-primary: #ff9f43; /* Màu cam ấm */
        --pet-secondary: #feca57; /* Màu vàng pastel */
        --pet-dark: #574b90; /* Màu tím sẫm thanh lịch */
        --pet-text: #4b4b4b;
        --pet-muted: #a4b0be;
        --pet-border: #f1f2f6;
        --pet-bg-light: #fffbf7;
        --radius-md: 16px;
        --radius-sm: 10px;
    }

    /* Định dạng lại các nút bấm từ kiểu cyber sang kiểu petshop bo tròn */
    .btn-pet {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 18px;
        font-family: 'Quicksand', sans-serif;
        font-weight: 700;
        border-radius: var(--radius-sm);
        text-decoration: none;
        transition: all 0.3s ease;
        font-size: 0.9rem;
        border: none;
        cursor: pointer;
    }

    .btn-pet-success {
        background: linear-gradient(135deg, #2ed573, #26af5f);
        color: white;
        box-shadow: 0 4px 12px rgba(46, 213, 115, 0.2);
    }

        .btn-pet-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(46, 213, 115, 0.3);
        }

    .btn-pet-primary {
        background: linear-gradient(135deg, var(--pet-primary), #ff7675);
        color: white;
        box-shadow: 0 4px 12px rgba(255, 159, 67, 0.2);
    }

        .btn-pet-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(255, 159, 67, 0.3);
        }

    .btn-pet-danger {
        background: linear-gradient(135deg, #ff6b6b, #ee5253);
        color: white;
        box-shadow: 0 4px 12px rgba(255, 107, 107, 0.2);
    }

        .btn-pet-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(255, 107, 107, 0.3);
        }

    .btn-pet-sm {
        padding: 6px 12px;
        font-size: 0.8rem;
    }

    /* Custom lại bảng hiển thị */
    .pet-table-wrapper {
        background: #ffffff;
        border-radius: var(--radius-md);
        border: 2px solid var(--pet-border);
        padding: 12px;
        box-shadow: 0 8px 24px rgba(87, 75, 144, 0.03);
        overflow-x: auto;
    }

    .pet-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Nunito', sans-serif;
    }

        .pet-table th {
            background: #fdf8f4;
            color: var(--pet-dark);
            font-weight: 700;
            padding: 14px 12px;
            text-align: left;
            border-bottom: 2px solid var(--pet-border);
            font-family: 'Quicksand', sans-serif;
        }

        .pet-table td {
            padding: 14px 12px;
            border-bottom: 1px solid var(--pet-border);
            color: var(--pet-text);
            vertical-align: middle;
        }

        .pet-table tbody tr:hover {
            background-color: #fffdfb;
        }

    /* Badge phong cách mượt mà */
    .pet-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .bg-pet-info {
        background: #e0f7fa;
        color: #006064;
    }

    .bg-pet-warning {
        background: #fff3e0;
        color: #e65100;
    }

    .bg-pet-success {
        background: #e8f5e9;
        color: #1b5e20;
    }

    .bg-pet-danger {
        background: #ffebee;
        color: #b71c1c;
    }

    .bg-pet-primary {
        background: #f3e5f5;
        color: #4a148c;
    }

    .bg-pet-secondary {
        background: #f5f5f5;
        color: #616161;
    }
</style>

<div class="animate-fade-in" style="font-family: 'Quicksand', sans-serif;">
    @* HEADER TRANG *@
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <h2 style="color: var(--pet-dark); font-weight: 700; margin: 0; font-size: 1.8rem;">Quản lý Banner</h2>
            <div class="subtitle" style="color: var(--pet-muted); font-size: 0.9rem; margin-top: 4px;">
                Thiết lập slideshow toàn màn hình cho trang chủ giao diện <strong style="color: var(--pet-primary);">Thien Pet Shop</strong>
            </div>
        </div>
        <a asp-action="Create" class="btn-pet btn-pet-success">
            <i class="fa-solid fa-paw"></i> Thêm banner mới
        </a>
    </div>

    @* ===== SLIDESHOW PREVIEW ===== *@
    @if (homeHeroBanners.Any())

    {
        <div style="margin-bottom: 2rem;">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
                <i class="fa-solid fa-images" style="color: var(--pet-primary); font-size: 1.2rem;"></i>
                <span style="font-weight: 700; font-size: 1.05rem; color: var(--pet-dark);">
                    Xem trước Slideshow trang chủ
                </span>
                <span class="pet-badge bg-pet-info">
                    @homeHeroBanners.Count slide • Tự động chuyển
                </span>
            </div>

            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">
                @for (int i = 0; i < homeHeroBanners.Count; i++)

                {

                    var b = homeHeroBanners[i];
                    <div style="position: relative; border-radius: var(--radius-md); overflow: hidden; border: 2px solid var(--pet-border); aspect-ratio: 16/9; background: #fafafa; box-shadow: 0 4px 14px rgba(0,0,0,0.03);">
                        @if (!string.IsNullOrEmpty(b.ImageUrl))

                        {
                            <img src="@b.ImageUrl" alt="@b.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                        }

                        else

                        {
                            <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #fdf8f4, #f5e6da); display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-paw" style="font-size: 2.5rem; color: var(--pet-muted); opacity: 0.5;"></i>
                            </div>
                        }

                        @* Overlay chứa thông tin Slide cấu trúc bo góc tròn nhẹ dễ nhìn *@
                        <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(87, 75, 144, 0.8) 0%, rgba(0,0,0,0) 70%); display: flex; flex-direction: column; justify-content: flex-end; padding: 16px;">
                            <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 6px;">
                                <span class="pet-badge bg-pet-warning" style="font-size: 0.65rem; color: #fff; background: var(--pet-secondary);">Slide @(i + 1)</span>
                                @if (b.IsActive)

                                {
                                    <span class="pet-badge bg-pet-success" style="font-size: 0.65rem; background: #2ed573; color:#fff;">Đang hiển thị</span>
                                }
                            </div>
                            <div style="color: #fff; font-weight: 700; font-size: 1.05rem; line-height: 1.3; font-family: 'Quicksand', sans-serif;">
                                @b.Title
                            </div>
                            @if (!string.IsNullOrEmpty(b.Description))
                            {
                                <div style="color: rgba(255,255,255,0.85); font-size: 0.8rem; margin-top: 3px; font-family: 'Nunito', sans-serif;">
                                    @b.Description
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    else

    {
        @* Giao diện trống kiểu Pet shop dễ thương *@
        <div style="background: #ffffff; border: 2px dashed var(--pet-primary); border-radius: var(--radius-md); padding: 3rem 2rem; text-align: center; margin-bottom: 2rem; box-shadow: 0 8px 20px rgba(255,159,67,0.02);">
            <i class="fa-solid fa-dog" style="font-size: 3.5rem; color: var(--pet-primary); margin-bottom: 1rem; display: block;"></i>
            <h4 style="color: var(--pet-dark); margin-bottom: 0.5rem; font-weight: 700;">Chưa có banner nào cho Slideshow</h4>
            <p style="color: var(--pet-muted); font-size: 0.9rem; margin-bottom: 1.5rem; max-width: 500px; margin-left: auto; margin-right: auto; font-family: 'Nunito', sans-serif;">
                Cửa hàng chưa thiết lập banner hiển thị lớn. Hãy thêm ít nhất <strong>3 banner</strong> ở vị trí <strong>"Home Hero"</strong> để giao diện trang chủ hoạt động thật nổi bật nhé!
            </p>
            <a asp-action="Create" class="btn-pet btn-pet-primary">
                <i class="fa-solid fa-plus"></i> Thiết lập banner ngay
            </a>
        </div>
    }

    @* ===== HƯỚNG DẪN ===== *@
    <div style="background: var(--pet-bg-light); border: 2px solid #ffecd9; border-radius: var(--radius-md); padding: 1.25rem; margin-bottom: 2rem; display: flex; align-items: flex-start; gap: 14px;">
        <i class="fa-solid fa-circle-info" style="color: var(--pet-primary); font-size: 1.2rem; margin-top: 2px;"></i>
        <div style="font-size: 0.88rem; color: var(--pet-text); line-height: 1.6; font-family: 'Nunito', sans-serif;">
            <strong style="color: var(--pet-dark); font-family: 'Quicksand', sans-serif; font-size: 0.95rem;">💡 Gợi ý thiết lập ảnh Banner cho Thien Pet Shop:</strong><br />
            • Kích thước tối ưu: <strong>1920×1080px</strong> (tỷ lệ chuẩn màn hình máy tính 16:9).<br />
            • Số lượng khuyến nghị: Giữ ở mức ổn định khoảng <strong>3 - 5 slide</strong> để tốc độ tải trang nhanh và mượt nhất.<br />
            • <strong>Thứ tự sắp xếp:</strong> Hệ thống ưu tiên chạy từ số nhỏ đến số lớn (Số 0 hiển thị đầu tiên).
        </div>
    </div>

    @* ===== BẢNG DANH SÁCH ===== *@
    <div class="pet-table-wrapper">
        <table class="pet-table">
            <thead>
                <tr>
                    <th style="width: 70px; text-align: center;">STT</th>
                    <th style="width: 200px;">Hình ảnh</th>
                    <th>Tiêu đề & Nội dung</th>
                    <th>Đường dẫn liên kết</th>
                    <th style="width: 110px; text-align: center;">Vị trí tuyển chọn</th>
                    <th style="width: 90px; text-align: center;">Thứ tự</th>
                    <th style="width: 120px; text-align: center;">Trạng thái</th>
                    <th style="width: 180px; text-align: center;">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int slideNum = 0;
                }
                @foreach (var item in allBanners)

                {
                    slideNum++;
                    <tr>
                        <td style="text-align: center;">
                            <span class="pet-badge bg-pet-secondary" style="font-family: 'Quicksand', sans-serif; font-size: 0.85rem; min-width: 28px; justify-content: center;">
                                @slideNum
                            </span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))

                            {
                                <div style="aspect-ratio: 16/9; width: 180px; border-radius: var(--radius-sm); overflow: hidden; border: 1px solid var(--pet-border); box-shadow: 0 2px 8px rgba(0,0,0,0.02);">
                                    <img src="@item.ImageUrl" alt="@item.Title" style="width: 100%; height: 100%; object-fit: cover;" />
                                </div>
                            }

                            else

                            {
                                <div style="aspect-ratio: 16/9; width: 180px; border-radius: var(--radius-sm); overflow: hidden; border: 1px dashed var(--pet-muted); background: #fafafa; display: flex; align-items: center; justify-content: center;">
                                    <span style="color: var(--pet-muted); font-size: 0.8rem; font-family: 'Quicksand', sans-serif;">Chưa gắn ảnh</span>
                                </div>
                            }
                        </td>
                        <td>
                            <div style="font-weight: 700; font-size: 1rem; color: var(--pet-dark); margin-bottom: 4px;">
                                @item.Title
                            </div>
                            @if (!string.IsNullOrEmpty(item.Description))

                            {
                                <div style="font-size: 0.85rem; color: var(--pet-muted); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @item.Description
                                </div>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.LinkUrl))

                            {
                                <a href="@item.LinkUrl" target="_blank" style="color: var(--pet-primary); text-decoration: none; font-weight: 600; font-size: 0.88rem; display: inline-flex; align-items: center; gap: 4px;">
                                    <i class="fa-solid fa-link" style="font-size: 0.75rem;"></i> Xem liên kết
                                </a>
                            }

                            else

                            {
                                <span style="color: var(--pet-muted); font-size: 0.85rem;">— Trống —</span>
                            }
                        </td>
                        <td style="text-align: center;">
                            @if (item.Position == "HomeHero")

                            {
                                <span class="pet-badge bg-pet-primary" style="color: #673ab7;">Trang chủ</span>
                            }

                            else

                            {
                                <span class="pet-badge bg-pet-secondary" style="text-transform: uppercase;">@item.Position</span>
                            }
                        </td>
                        <td style="text-align: center; font-weight: 700; color: var(--pet-dark); font-size: 1rem;">
                            @item.SortOrder
                        </td>
                        <td style="text-align: center;">
                            @if (item.IsActive)

                            {
                                <span class="pet-badge bg-pet-success" style="color: #2ed573; padding: 6px 12px;">
                                    <i class="fa-solid fa-circle" style="font-size: 0.5rem; margin-right: 2px;"></i> Hiển thị
                                </span>
                            }

                            else

                            {
                                <span class="pet-badge bg-pet-danger" style="color: #ff6b6b; padding: 6px 12px;">
                                    <i class="fa-solid fa-circle" style="font-size: 0.5rem; margin-right: 2px;"></i> Đang ẩn
                                </span>
                            }
                        </td>
                        <td style="text-align: center;">
                            <div style="display: flex; gap: 6px; justify-content: center;">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-pet btn-pet-primary btn-pet-sm">
                                    <i class="fa-solid fa-pen-to-square"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-pet btn-pet-danger btn-pet-sm">
                                    <i class="fa-solid fa-trash-can"></i> Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!allBanners.Any())

                {
                    <tr>
                        <td colspan="8" style="text-align: center; color: var(--pet-muted); padding: 3rem 0; font-family: 'Quicksand', sans-serif;">
                            <i class="fa-solid fa-folder-open" style="font-size: 2rem; display: block; margin-bottom: 8px; color: #ddd;"></i>
                            Hệ thống dữ liệu trống. Hãy nhấn nút thêm mới để tạo dữ liệu!
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>