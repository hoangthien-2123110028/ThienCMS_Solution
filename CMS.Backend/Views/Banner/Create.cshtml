@model CMS.Data.Entities.Banner

@{
    ViewData["Title"] = "Thêm banner mới";
}

<div class="animate-fade-in">
    <div class="page-header mb-4">
        <div>
            <h2 style="color: #ff9a3c; font-weight: 800;"><i class="fa-solid fa-circle-plus"></i> Thêm banner thú cưng mới</h2>
            <div class="subtitle" style="color: #a6a5a9;">Tạo slide chương trình ưu đãi lớn nổi bật ở đầu trang chủ</div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="pet-form-container" style="border: 1px solid #2d2b33; background: #1a191d; padding: 2.5rem; border-radius: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.2);">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-4">
                        <label class="pet-label" style="color: #f3f3f4; font-weight: 700; margin-bottom: 0.5rem; display: block;">Tiêu đề banner <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="pet-input" placeholder="Ví dụ: Đón Tết Xúng Xính - Giảm 20% Đồ Tết Cho Thú Cưng" style="width: 100%; background: #111013; border: 1px solid #3d3b44; color: #fff; padding: 0.75rem 1rem; border-radius: 10px;" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                        <small style="color: #a6a5a9;" class="mt-1 d-block">
                            Tiêu đề hiển thị trung tâm. Nhấn Enter tại ô nhập nếu muốn chủ động xuống dòng văn bản.
                        </small>
                    </div>

                    <div class="form-group mb-4">
                        <label class="pet-label" style="color: #f3f3f4; font-weight: 700; margin-bottom: 0.5rem; display: block;">Mô tả ngắn (phụ đề)</label>
                        <textarea asp-for="Description" class="pet-input" rows="2" placeholder="Ví dụ: Áp dụng khi mua kèm pate bất kỳ" style="width: 100%; background: #111013; border: 1px solid #3d3b44; color: #fff; padding: 0.75rem 1rem; border-radius: 10px;"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label class="pet-label" style="color: #f3f3f4; font-weight: 700; margin-bottom: 0.5rem; display: block;">Chọn hình ảnh chất lượng cao <span class="text-danger">*</span></label>
                        <input type="file" name="ImageFile" accept="image/*" class="pet-input" required id="bannerImageInput" style="width: 100%; background: #111013; border: 1px solid #3d3b44; color: #fff; padding: 0.75rem; border-radius: 10px;" />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        <small style="color: #a6a5a9;" class="mt-1 d-block">
                            <i class="fa-solid fa-circle-info" style="color: #ff9a3c;"></i>
                            <strong>Chuẩn khung hình: 1920×1080px (16:9)</strong> để ảnh bao phủ toàn màn hình đẹp mắt nhất.
                        </small>

                        @* Image preview *@
                        <div id="imagePreviewWrapper" style="display: none; margin-top: 12px;">
                            <label class="pet-label" style="font-size: 0.85rem; margin-bottom: 6px; color: #ff9a3c; font-weight: 700;">Xem trước thiết kế hiển thị công cộng:</label>
                            <div style="position: relative; aspect-ratio: 16/9; max-width: 100%; border-radius: 12px; overflow: hidden; border: 2px solid #ff9a3c; background: #111;">
                                <img id="imagePreview" src="" alt="Preview" style="width: 100%; height: 100%; object-fit: cover;" />
                                <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.75) 100%); display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 8px;">
                                    <span style="background: #ff9a3c; padding: 4px 16px; border-radius: 999px; font-size: 0.75rem; color: #111013; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 800;">NHÃN PHỤ ĐỀ SẼ Ở ĐÂY</span>
                                    <span style="color: #fff; font-size: 1.8rem; font-weight: 900; text-shadow: 0 2px 10px rgba(0,0,0,0.8);">TIÊU ĐỀ KHUYẾN MÃI</span>
                                    <div style="display: flex; gap: 8px;">
                                        <span style="background: #fff; color: #ff8210; padding: 6px 18px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; border-radius: 20px;">Mua Ngay →</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="pet-label" style="color: #f3f3f4; font-weight: 700; margin-bottom: 0.5rem; display: block;">Đường dẫn chuyển tiếp khi Click</label>
                        <input asp-for="LinkUrl" class="pet-input" placeholder="Ví dụ: /danh-muc/pate-meo" style="width: 100%; background: #111013; border: 1px solid #3d3b44; color: #fff; padding: 0.75rem 1rem; border-radius: 10px;" />
                        <span asp-validation-for="LinkUrl" class="text-danger"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="pet-label" style="color: #f3f3f4; font-weight: 700; margin-bottom: 0.5rem; display: block;">Vị trí đặt banner</label>
                                <select asp-for="Position" class="pet-input" style="width: 100%; background: #111013; border: 1px solid #3d3b44; color: #fff; padding: 0.75rem; border-radius: 10px;">
                                    <option value="HomeHero">🏠 Home Hero (Slideshow trang chủ)</option>
                                    <option value="Sidebar">📐 Sidebar (Cột phụ bên cạnh)</option>
                                    <option value="MiddleBanner">📄 Middle Banner (Banner quảng cáo giữa trang)</option>
                                </select>
                                <span asp-validation-for="Position" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="pet-label" style="color: #f3f3f4; font-weight: 700; margin-bottom: 0.5rem; display: block;">Thứ tự xuất hiện</label>
                                <input asp-for="SortOrder" type="number" class="pet-input" min="0" placeholder="Số nhỏ xếp trước" style="width: 100%; background: #111013; border: 1px solid #3d3b44; color: #fff; padding: 0.75rem; border-radius: 10px;" />
                                <span asp-validation-for="SortOrder" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <div class="form-check form-switch mt-2">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch" checked style="cursor: pointer; width: 2.5em; height: 1.25em;">
                            <label class="form-check-label pet-label" for="isActiveSwitch" style="padding-left: 10px; cursor: pointer; display: inline-block; color: #f3f3f4; font-weight: 600;">Kích hoạt xuất bản hiển thị ngay</label>
                        </div>
                        <span asp-validation-for="IsActive" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4" style="border-top: 1px solid #2d2b33; padding-top: 1.5rem;">
                        <button type="submit" class="btn" style="background: linear-gradient(135deg, #ff9a3c, #ff8210); color: #fff; font-weight: 700; padding: 0.75rem 1.75rem; border-radius: 30px; border: none; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(255, 130, 16, 0.3);">
                            <i class="fa-solid fa-floppy-disk"></i> Lưu banner mới
                        </button>
                        <a asp-action="Index" class="btn" style="background: #2d2b33; color: #f3f3f4; font-weight: 600; padding: 0.75rem 1.5rem; border-radius: 30px; border: none; display: flex; align-items: center; gap: 8px; text-decoration: none;">
                            <i class="fa-solid fa-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.getElementById('bannerImageInput').addEventListener('change', function (e) {
            const file = e.target.files[0];
            const wrapper = document.getElementById('imagePreviewWrapper');
            const preview = document.getElementById('imagePreview');

            if (file) {
                const reader = new FileReader();
                reader.onload = function (ev) {
                    preview.src = ev.target.result;
                    wrapper.style.display = 'block';
                };
                reader.readAsDataURL(file);
            } else {
                wrapper.style.display = 'none';
            }
        });
    </script>
}