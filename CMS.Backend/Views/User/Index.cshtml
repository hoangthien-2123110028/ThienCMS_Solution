@model IEnumerable<CMS.Data.Entities.User>

<div class="container mt-4">

    <h2 class="mb-4 text-success">
        DANH SÁCH THÀNH VIÊN
    </h2>

    <table class="table table-bordered">

        <thead>
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>FullName</th>
                <th>Role</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Id</td>

                    <td>@item.Username</td>

                    <td>@item.FullName</td>

                    <td>@item.Role</td>

                </tr>
            }

        </tbody>

    </table>

</div>