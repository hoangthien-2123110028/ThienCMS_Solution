@model IEnumerable<CMS.Data.Entities.User>

@{
    ViewData["Title"] = "Quản lý thành viên";
}

<div class="animate-fade-in">
    <div class="page-header">
        <div>
            <h2>Thành viên</h2>
            <div class="subtitle">Quản lý tài khoản và phân quyền hệ thống</div>
        </div>
        <a asp-action="Create" class="btn-cyber btn-cyber-success">
            <i class="fa-solid fa-plus"></i> Thêm thành viên
        </a>
    </div>

    <div class="cyber-table-wrapper">
        <table class="cyber-table">
            <thead>
                <tr>
                    <th class="text-center">ID</th>
                    <th>Tên đăng nhập</th>
                    <th>Họ và tên</th>
                    <th class="text-center">Vai trò</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr class="empty-row">
                        <td colspan="5">Chưa có thành viên nào trong hệ thống.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@item.Id</td>
                            <td><b>@item.Username</b></td>
                            <td>@item.FullName</td>
                            <td class="text-center">
                                @if (item.Role == "Admin")
                                {
                                    <span class="badge-cyber badge-cyber-danger">
                                        <i class="fa-solid fa-shield-halved"></i> Admin
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-cyber badge-cyber-info">
                                        <i class="fa-solid fa-pen-nib"></i> Editor
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-cyber btn-cyber-primary btn-cyber-sm">
                                    <i class="fa-solid fa-pen"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-cyber btn-cyber-danger btn-cyber-sm">
                                    <i class="fa-solid fa-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
